# Server
PORT=3001
NODE_ENV=development

# Box
BOX_CONFIG_PATH=../box_config.json
BOX_ROOT_FOLDER_ID=0

# CORS
FRONTEND_URL=http://localhost:5173

# Your Box account email (for folder collaboration visibility)
BOX_ADMIN_EMAIL=

# Database
DB_DIALECT=sqlite
DATABASE_URL=./data/taxflow.db
DB_POOL_MIN=2
DB_POOL_MAX=10
